{
  "name": "devksingh4-web",
  "version": "1.0.0",
  "private": true,
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "deploy": "yarn run build && wrangler deploy",
    "dev": "astro dev",
    "format:check": "prettier . --check && eslint .",
    "format:fix": "prettier . --write && eslint . --fix",
    "postinstall": "npm run setup && husky install",
    "prepare": "husky install || true",
    "prettier:write": "prettier . --write",
    "preview": "yarn run build && wrangler dev",
    "setup": "git config blame.ignoreRevsFile .git-blame-ignore-revs",
    "typecheck": "astro check"
  },
  "lint-staged": {
    "*.{ts,tsx,astro,js,css,md,mdx,json}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@iconify-json/lucide": "^1.2.102",
    "astro-compress": "^2.4.1",
    "geist": "^1.7.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.4",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@typescript-eslint/parser": "^8.59.0",
    "astro": "^6.1.9",
    "astro-eslint-parser": "^1.4.0",
    "astro-icon": "^1.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^8.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "wrangler": "^4.85.0"
  }
}
