---
import { Image } from 'astro:assets';
import { portfolio } from '../data/portfolio';
import profilePic from '../assets/me.webp';

const { email, github, githubUrl, linkedin } = portfolio.links;
---

<!-- Self-contained contact card: compact, screenshot-friendly, on-palette. -->
<div
  class="flex w-full max-w-[420px] items-center gap-5 rounded-xl border border-rule bg-card p-5 sm:p-6"
>
  <Image
    src={profilePic}
    alt={portfolio.name}
    width={240}
    height={240}
    densities={[1, 2]}
    class="h-20 w-20 shrink-0 rounded-lg object-cover sm:h-24 sm:w-24"
  />
  <div class="min-w-0">
    <div class="flex items-center gap-2">
      <span class="h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"
      ></span>
      <span class="text-[18px] font-medium">{portfolio.name}</span>
    </div>
    <div class="label-caps mt-1">{portfolio.role} · {portfolio.location}</div>
    <div class="mt-3 grid gap-1 text-[13px]">
      <a
        href={`mailto:${email}`}
        class="text-muted transition-colors hover:text-accent"
      >
        {email}
      </a>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted transition-colors hover:text-accent"
      >
        github.com/{github}
      </a>
      <a
        href={`https://linkedin.com/in/${linkedin}`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted transition-colors hover:text-accent"
      >
        linkedin.com/in/{linkedin}
      </a>
    </div>
  </div>
</div>
