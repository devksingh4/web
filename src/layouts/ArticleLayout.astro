---
import Layout from './Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import CommandPalette from '../components/CommandPalette.astro';
import { siteNav } from '../data/siteNav';

interface Props {
  title: string;
  description?: string;
  tags: string[];
  byline: string;
  date: string;
  excerpt: string;
}

const { title, description, tags, byline, date, excerpt } = Astro.props;
---

<Layout
  title={`${title} — Dev Singh`}
  description={description ?? excerpt}
  ogType="article"
>
  <div class="mx-auto max-w-[900px] px-6 pt-16 pb-24 sm:px-12">
    <SiteHeader nav={siteNav} base="/" active="blog" />

    <a
      href="/blog"
      class="ln mt-8 inline-block text-[13px] text-muted hover:text-fg"
    >
      ← All posts
    </a>

    <article class="pt-6">
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => <span class="pill">{tag}</span>)}
      </div>
      <h1
        class="mt-5 text-[34px] leading-[1.08] font-medium tracking-[-1px] sm:text-[44px]"
      >
        {title}
      </h1>
      <div
        class="mt-4 flex flex-wrap items-center gap-2 text-[13px] text-muted"
      >
        <span>{byline}</span>
        <span aria-hidden="true">·</span>
        <span>{date}</span>
      </div>
      <p
        class="mt-6 border-l-2 border-rule pl-4 text-[17px] leading-relaxed text-muted italic"
      >
        {excerpt}
      </p>

      <hr class="my-8 border-0 border-t border-rule" />

      <div class="prose-content">
        <slot />
      </div>
    </article>

    <div class="mt-12 border-t border-rule pt-6">
      <a href="/blog" class="ln text-[13px] text-muted hover:text-fg">
        ← Back to blog
      </a>
    </div>
  </div>

  <CommandPalette nav={siteNav} />
</Layout>
