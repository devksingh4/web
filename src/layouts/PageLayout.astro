---
import Layout from './Layout.astro';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
}

const { title, description, wide = false } = Astro.props;
---

<Layout title={title} description={description}>
  <div
    class={`w-full bg-black/80 border border-white/10 rounded-lg text-white p-10 sm:p-12 space-y-8 min-h-[18rem] ${wide ? 'max-w-4xl' : 'max-w-3xl'}`}
  >
    <slot />
  </div>
</Layout>
