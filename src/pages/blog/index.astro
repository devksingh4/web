---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import PostList from '../../components/PostList.astro';
import { siteNav } from '../../data/siteNav';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.published)).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="Blog — Dev Singh" description="Writing by Dev Singh.">
  <div class="mx-auto max-w-[900px] px-6 pt-16 pb-24 sm:px-12">
    <SiteHeader nav={siteNav} base="/" active="blog" />

    <div class="pt-12">
      <div class="label-caps">Blog</div>
      <h1
        class="mt-3 text-[34px] leading-[1.08] font-medium tracking-[-1px] sm:text-[44px]"
      >
        Writing.
      </h1>
      <p class="mt-4 text-[15px] text-muted">
        {posts.length}
        {posts.length === 1 ? 'post' : 'posts'}.
      </p>

      <div class="mt-10">
        <PostList posts={posts} />
      </div>
    </div>

    <div class="mt-12 border-t border-rule pt-6">
      <a href="/" class="ln text-[13px] text-muted hover:text-fg">← Back home</a
      >
    </div>
  </div>

  <CommandPalette nav={siteNav} />
</Layout>

<script>
  import { initReveal } from '../../scripts/reveal';

  initReveal();
</script>
