---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.published)).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<PageLayout title="Blog — Dev Singh" wide fullHeight>
  <div class="text-center space-y-2">
    <h1 class="text-3xl font-bold">Blog</h1>
    <p class="text-white/80">
      Thoughts on technology, engineering, and building systems.
    </p>
  </div>

  <div class="space-y-4">
    {
      posts.length === 0 ? (
        <p class="text-center text-white/50">
          No posts found. Please check back later!
        </p>
      ) : (
        posts.map((post) => (
          <a href={`/blog/${post.id}`} class="block">
            <div class="bg-white/5 rounded-lg p-6 hover:bg-white/10 transition-colors space-y-3">
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="px-2 py-0.5 rounded-full text-xs bg-purple-600/20 text-purple-200 border border-purple-400/20">
                    {tag}
                  </span>
                ))}
              </div>
              <h3 class="text-xl font-semibold">{post.data.title}</h3>
              <p class="text-white/90 leading-relaxed">{post.data.excerpt}</p>
              <div class="flex items-center justify-between text-sm text-white/70">
                <span>{post.data.date}</span>
                <span>{post.data.byline}</span>
              </div>
            </div>
          </a>
        ))
      )
    }
  </div>
</PageLayout>
