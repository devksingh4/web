---
import PageLayout from '../layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import { portfolio } from '../data/portfolio';
---

<PageLayout title="Background — Dev Singh" wide>
  <div class="text-center">
    <h1 class="text-3xl font-bold">Background</h1>
  </div>

  <section class="space-y-6">
    <h2 class="text-2xl font-semibold border-b border-white/20 pb-2">
      Experience
    </h2>
    {
      portfolio.experience.map((exp) => (
        <div class="bg-white/5 rounded-lg p-6 space-y-4">
          <div class="flex items-center justify-between">
            <h3 class="text-xl font-semibold">{exp.company}</h3>
            <a
              href={exp.link}
              target="_blank"
              class="text-white/60 hover:text-white/80 transition-colors"
            >
              <Icon name="lucide:external-link" class="w-4 h-4" />
            </a>
          </div>
          {exp.positions.map((pos) => (
            <div class="border-l-2 border-white/20 pl-4 space-y-2">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                <h4 class="font-medium text-lg">{pos.title}</h4>
                <div class="flex items-center gap-2 text-sm text-white/70">
                  <Icon name="lucide:map-pin" class="w-3 h-3 shrink-0" />
                  <span>{pos.location}</span>
                  <span>•</span>
                  <span>{pos.dates}</span>
                </div>
              </div>
              <ul class="space-y-1">
                {pos.bullets.map((bullet) => (
                  <li class="text-sm text-white/90 leading-relaxed">
                    • {bullet}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ))
    }
  </section>

  <section class="space-y-6">
    <h2 class="text-2xl font-semibold border-b border-white/20 pb-2">
      Education
    </h2>
    {
      portfolio.education.map((edu) => (
        <div class="bg-white/5 rounded-lg p-6 space-y-4">
          <div class="flex items-center justify-between">
            <h3 class="text-xl font-semibold">{edu.company}</h3>
            <a
              href={edu.link}
              target="_blank"
              class="text-white/60 hover:text-white/80 transition-colors"
            >
              <Icon name="lucide:external-link" class="w-4 h-4" />
            </a>
          </div>
          {edu.positions.map((pos) => (
            <div class="border-l-2 border-white/20 pl-4 space-y-2">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                <h4 class="font-medium text-lg">{pos.title}</h4>
                <div class="flex items-center gap-2 text-sm text-white/70">
                  <Icon name="lucide:calendar" class="w-3 h-3 shrink-0" />
                  <span>{pos.dates}</span>
                </div>
              </div>
              {pos.bullets.length > 0 && (
                <ul class="space-y-1">
                  {pos.bullets.map((bullet) => (
                    <li class="text-sm text-white/90 leading-relaxed">
                      • {bullet}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </div>
      ))
    }
  </section>
</PageLayout>
