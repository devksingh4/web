---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found" description="Page not found">
  <div
    class="bg-black/80 border border-white/10 rounded-lg text-white px-12 py-14 flex flex-col items-center text-center space-y-6 min-h-[18rem] min-w-[20rem]"
  >
    <h1 class="text-7xl font-bold">404</h1>
    <p class="text-xl text-white/80">This page doesn't exist.</p>
    <a
      href="/"
      class="inline-block px-5 py-2 rounded-md border border-white/20 hover:bg-white/10 transition-colors"
    >
      Back home
    </a>
  </div>
</Layout>
