---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found" description="Page not found">
  <main
    class="mx-auto flex min-h-screen max-w-[1536px] flex-col items-center justify-center gap-6 px-6 text-center"
  >
    <div class="label-caps">Error 404</div>
    <h1 class="text-[64px] leading-none font-medium tracking-[-1.2px]">
      Not found.
    </h1>
    <p class="text-[15px] text-muted">This page doesn’t exist.</p>
    <a href="/" class="ln text-[14px]">← Back home</a>
  </main>
</Layout>
