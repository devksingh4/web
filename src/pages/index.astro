---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Work from '../components/Work.astro';
import Blog from '../components/Blog.astro';
import Experience from '../components/Experience.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CommandPalette from '../components/CommandPalette.astro';
import { siteNav } from '../data/siteNav';

// Reorder this list and the section numbers (01, 02, …) follow automatically.
// The navbar order is shared with sub-pages via `siteNav` — keep its ids in
// sync with the section ids (Hero is `about`, Work `work`, …).
const sections = [Hero, About, Experience, Work, Blog];
---

<Layout title="Dev Singh — Software Engineer">
  <main class="mx-auto max-w-[1536px] px-6 pt-6 pb-24 sm:px-12 lg:px-[88px]">
    <SiteHeader nav={siteNav} />
    {sections.map((Section, i) => <Section index={i + 1} />)}
    <SiteFooter />
  </main>
  <CommandPalette nav={siteNav} />
</Layout>

<script>
  import { smoothScrollTo } from '../scripts/smoothScroll';
  import { initReveal } from '../scripts/reveal';

  const navLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('[data-nav][href^="#"]')
  );
  const sections = Array.from(
    document.querySelectorAll<HTMLElement>('main section[id]')
  );

  // Shared so the click handler and the scroll spy don't fight: the spy pauses
  // briefly after a click-scroll, and both track the last hash written.
  let spyPausedUntil = 0;
  let currentHash = location.hash;

  // Mark the nav link for `hash` (e.g. '#work') as the current section.
  function highlight(hash: string) {
    navLinks.forEach((l) => {
      const on = l.getAttribute('href') === hash;
      l.classList.toggle('text-accent', on);
      if (on) l.setAttribute('aria-current', 'true');
      else l.removeAttribute('aria-current');
    });
  }

  // Anchor nav: intercept in-page links and scroll smoothly.
  navLinks.forEach((a) => {
    a.addEventListener('click', (e) => {
      const href = a.getAttribute('href') || '';
      e.preventDefault();
      smoothScrollTo(href);
      history.replaceState(null, '', href);
      currentHash = href;
      highlight(href);
      spyPausedUntil = Date.now() + 800;
    });
  });

  // Scroll spy: reflect the section at the top of the viewport in the URL hash
  // (replaceState — no history entries) and highlight its nav link. URL writes
  // happen on scroll only, so a fresh `/` or deep link is left alone until you
  // move; the highlight is synced once up front too.
  if (sections.length > 0) {
    const sync = (writeUrl: boolean) => {
      let active = sections[0];
      for (const sec of sections) {
        if (sec.getBoundingClientRect().top <= 80) active = sec;
      }
      const hash = `#${active.id}`;
      highlight(hash);
      if (writeUrl && hash !== currentHash) {
        currentHash = hash;
        history.replaceState(null, '', hash);
      }
    };
    sync(false);
    let ticking = false;
    window.addEventListener(
      'scroll',
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          ticking = false;
          if (Date.now() < spyPausedUntil) return;
          sync(true);
        });
      },
      { passive: true }
    );
  }

  initReveal();
</script>
